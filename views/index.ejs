<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student List App</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    
    <style>
        table { width: 100%; border-collapse: collapse; font-family: sans-serif; }
        th, td { padding: 12px; text-align: center; border-bottom: 1px solid #ddd; vertical-align: middle; }
        th { font-weight: bold; background-color: #f8f9fa; }
        .student-img { max-width: 80px; height: auto; object-fit: cover; }
    </style>
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
      <div class="container-fluid">
        <a class="navbar-brand" href="/">🎓 Student App</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="collapsibleNavbar">
          <ul class="navbar-nav ms-auto">
            <li class="nav-item">
              <a class="nav-link" href="/addstudent">Add New Student</a>
            </li> 
          </ul>
        </div>
      </div>
    </nav>

    <div class="container mt-5">
        <div class="card shadow p-4 bg-white">
            <h1 class="mb-4 text-secondary text-center">Student Database</h1>

            <div class="table-responsive">
                <table>
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Image</th>
                            <th>DOB</th>
                            <th>Contact</th>
                            <th>Edit</th>
                            <th>Delete</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% for(let i=0; i < students.length; i++) { %>
                            <tr>
                                <td>
                                    <a href="/student/<%= students[i].studentId %>" class="text-decoration-none fw-bold">
                                        <%= students[i].name %>
                                    </a>
                                </td>
                                
                                <td>
                                    <img src="images/<%= students[i].image %>" class="student-img">
                                </td>
                                
                                <td><%= students[i].dob %></td>
                                <td><%= students[i].contactNumber %></td>
                                
                                <td>
                                    <a href="/updateStudent/<%= students[i].studentId %>" class="btn btn-sm btn-outline-warning">Edit</a>
                                </td>
                                
                                <td>
                                    <a href="/deleteStudent/<%= students[i].studentId %>" 
                                       class="btn btn-sm btn-outline-danger"
                                       onclick="return confirm('Are you sure you want to delete this student?')">
                                        Delete
                                    </a>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div> 
        </div>
    </div>

</body>
</html>