<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Profile</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 0; padding: 0; background-color: #ffffff; }
        .container { max-width: 500px; margin: 40px auto; text-align: center; border: 1px solid #eaeaea; padding: 20px; border-radius: 8px; }
        .profile-large { width: 150px; height: 150px; border-radius: 50%; object-fit: cover; margin-bottom: 20px; }
        h2 { margin: 10px 0; color: #333; }
        p { color: #666; font-size: 16px; margin: 5px 0; }
        .back-link { display: inline-block; margin-top: 20px; color: #0d6efd; text-decoration: none; }
    </style>
</head>
<body>

    <%- include('navbar') %>

    <div class="container">
        <% if (typeof student !== 'undefined' && student) { %>
            <img src="<%= student.image %>" alt="<%= student.studentName %>" class="profile-large">
            <h2><%= student.studentName %></h2>
            <p><strong>Date of Birth:</strong> <%= student.dob %></p>
            <p><strong>Contact Info:</strong> <%= student.contactNumber %></p>
        <% } else { %>
            <h2>No student records found</h2>
        <% } %>
        <br>
        <a href="/" class="back-link">← Back to Dashboard</a>
    </div>

</body>
</html>