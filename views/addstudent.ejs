<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add New Student</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
            background-color: #ffffff;
        }

        .container {
            max-width: 600px;
            margin: 40px auto;
            text-align: center;
        }

        h1 {
            font-weight: normal;
            font-size: 28px;
            margin-bottom: 30px;
            color: #222;
        }

        .form-group {
            margin-bottom: 20px;
        }

        label {
            display: block;
            margin-bottom: 5px;
            font-size: 15px;
            color: #333;
        }

        input[type="text"],
        input[type="date"] {
            width: 220px;
            padding: 4px 6px;
            border: 1px solid #999;
            font-family: inherit;
            font-size: 14px;
        }

        button {
            margin-top: 15px;
            padding: 5px 15px;
            background-color: #f0f0f0;
            border: 1px solid #000;
            cursor: pointer;
            font-size: 14px;
        }

        button:hover {
            background-color: #e0e0e0;
        }
    </style>
</head>
<body>
    
    <!-- This pulls in the dark top bar from your partial file -->
    <%- include('navbar') %>
    
    <div class="container">
        <h1>Add New Student</h1>
        
        <!-- The form action should point to your Express POST route -->
        <form action="/student" method="POST">
            
            <div class="form-group">
                <label for="studentName">Student Name:</label>
                <input type="text" id="studentName" name="studentName" value="Anne John">
            </div>

            <div class="form-group">
                <label for="dob">D.o.B:</label>
                <!-- Note: input type="date" expects standard YYYY-MM-DD format -->
                <input type="date" id="dob" name="dob" value="2007-11-11">
            </div>

            <div class="form-group">
                <label for="contact">Contact:</label>
                <input type="text" id="contact" name="contact" value="87654321">
            </div>

            <div class="form-group">
                <label for="image">Image:</label>
                <input type="text" id="image" name="image" value="https://plus.unsplash.com">
            </div>

            <button type="submit">Add Student</button>
            
        </form>
    </div>

</body>
</html>